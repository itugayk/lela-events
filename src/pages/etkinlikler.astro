---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import Ornament from '../components/Ornament.astro';
import { events } from '../data/events';
import { img } from '../data/site';
---

<Layout title="Gerçek Etkinlikler" description="Lela Events ile hayata geçen gerçek düğün ve etkinlik hikayeleri.">
  <PageHero
    kicker="Gerçek Etkinlikler"
    title="Referans hikayeler"
    subtitle="Her biri kendine özgü, gerçek çiftlerin gerçek günleri. İşte birlikte yazdığımız masallar."
    image={img('1464366400600-7168b8af9bc3', 1800)}
  />

  <section class="bg-ivory py-20 lg:py-28">
    <div class="mx-auto max-w-6xl space-y-28 px-6 lg:px-10">
      {
        events.map((e, i) => (
          <article id={e.slug} class="scroll-mt-28">
            <div class:list={['grid items-center gap-10 lg:grid-cols-12 lg:gap-14']}>
              <!-- Kapak -->
              <div class:list={['lg:col-span-7', i % 2 === 1 ? 'lg:order-2' : '']} data-reveal>
                <div class="relative overflow-hidden rounded-[2rem]">
                  <img src={e.cover} alt={`${e.couple} — ${e.type}`} loading="lazy" class="aspect-[4/3] w-full object-cover" />
                </div>
              </div>

              <!-- Hikaye -->
              <div class="lg:col-span-5" data-reveal data-delay="0.1">
                <p class="text-[0.65rem] uppercase tracking-luxe text-champagne-700">{e.type} · {e.date}</p>
                <h2 class="mt-3 font-display text-5xl leading-none">{e.couple}</h2>
                <p class="mt-3 flex items-center gap-2 text-sm text-ink/55">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M12 21s-6-5.3-6-10a6 6 0 1 1 12 0c0 4.7-6 10-6 10Z"/><circle cx="12" cy="11" r="2"/></svg>
                  {e.location} · {e.guests} davetli
                </p>
                <p class="mt-6 text-base font-light leading-relaxed text-ink/70">{e.story}</p>

                <!-- Palet -->
                <div class="mt-7 flex items-center gap-3">
                  <span class="text-[0.6rem] uppercase tracking-wide-sm text-ink/45">Palet</span>
                  <div class="flex gap-2">
                    {e.palette.map((c) => (
                      <span class="h-7 w-7 rounded-full border border-ink/10" style={`background:${c}`} title={c}></span>
                    ))}
                  </div>
                </div>
              </div>
            </div>

            <!-- Mini galeri -->
            <div class="mt-6 grid grid-cols-3 gap-4" data-stagger>
              {
                e.gallery.map((g) => (
                  <div class="overflow-hidden rounded-xl" data-stagger-item>
                    <img src={g} alt={`${e.couple} detay`} loading="lazy" class="aspect-square w-full object-cover transition-transform duration-700 hover:scale-110" />
                  </div>
                ))
              }
            </div>
          </article>
        ))
      }

      <div class="text-center" data-reveal>
        <Ornament label="Sıradaki siz olun" />
        <h2 class="mt-6 font-display text-4xl">Hikayenizi birlikte yazalım</h2>
        <a href="/iletisim" class="btn-sheen mt-8 inline-block rounded-full bg-sage-500 px-9 py-3.5 text-sm uppercase tracking-wide-sm text-ivory transition-transform hover:scale-105">
          Teklif Al
        </a>
      </div>
    </div>
  </section>
</Layout>
