---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import MultiStepForm from '../components/MultiStepForm.astro';
import { img, site } from '../data/site';

const contactCards = [
  { label: 'Telefon', value: site.phone, href: `tel:${site.phoneHref}`, icon: 'M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3-8.7A2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7c.1 1 .4 1.9.7 2.8a2 2 0 0 1-.5 2.1L8.1 9.9a16 16 0 0 0 6 6l1.3-1.3a2 2 0 0 1 2.1-.4c.9.3 1.8.6 2.8.7a2 2 0 0 1 1.7 2Z' },
  { label: 'E-posta', value: site.email, href: `mailto:${site.email}`, icon: 'M4 4h16v16H4zM4 6l8 6 8-6' },
  { label: 'WhatsApp', value: site.whatsapp, href: '#', icon: 'M12 2a10 10 0 0 0-8.5 15.3L2 22l4.8-1.4A10 10 0 1 0 12 2Z' },
  { label: 'Atölye', value: site.address, href: '#', icon: 'M12 21s-6-5.3-6-10a6 6 0 1 1 12 0c0 4.7-6 10-6 10Z' },
];
---

<Layout title="Teklif Al & İletişim" description="Düğün veya etkinliğiniz için ücretsiz konsept ve teklif alın. Lela Events ile iletişime geçin.">
  <PageHero
    kicker="Teklif Al"
    title="Başlayalım"
    subtitle="Birkaç adımda bize hayalinizden bahsedin — size özel bir konsept ve teklifle dönelim."
    image={img('1511285560929-80b456fea0bc', 1800)}
  />

  <!-- İletişim kartları -->
  <section class="bg-cream py-16">
    <div class="mx-auto max-w-6xl px-6 lg:px-10">
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4" data-stagger>
        {
          contactCards.map((c) => (
            <a href={c.href} class="group flex flex-col items-center gap-3 rounded-2xl border border-champagne-200/70 bg-ivory px-5 py-7 text-center transition-all hover:-translate-y-1 hover:border-sage-400" data-stagger-item>
              <span class="flex h-12 w-12 items-center justify-center rounded-full bg-sage-100 text-sage-600 transition-colors group-hover:bg-sage-500 group-hover:text-ivory">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d={c.icon}/></svg>
              </span>
              <span class="text-[0.6rem] uppercase tracking-luxe text-champagne-700">{c.label}</span>
              <span class="text-sm text-ink/70">{c.value}</span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <MultiStepForm />
</Layout>
