---
import { processSteps } from '../data/misc';
import Ornament from './Ornament.astro';
import { img } from '../data/site';
const sideImg = img('1606216794074-735e91aa2c92', 1000);
---

<section class="relative overflow-hidden bg-sage-800 py-24 text-cream lg:py-32">
  <!-- arka plan dokusu -->
  <div class="glow-soft pointer-events-none absolute -right-32 top-10 h-[30rem] w-[30rem] opacity-30"></div>

  <div class="mx-auto max-w-7xl px-6 lg:px-10">
    <div class="flex flex-col items-center text-center" data-reveal-fade>
      <Ornament label="Sürecimiz" light />
      <h2 class="mt-6 font-display text-4xl leading-tight sm:text-5xl">
        İlk görüşmeden o güne, <span class="italic text-champagne-300">yanınızdayız</span>
      </h2>
    </div>

    <div class="mt-16 grid items-center gap-14 lg:grid-cols-2">
      <!-- Timeline -->
      <ol class="relative" id="process-timeline">
        <!-- ilerleyen çizgi -->
        <span class="absolute left-[1.45rem] top-2 h-full w-px bg-cream/15"></span>
        <span class="absolute left-[1.45rem] top-2 w-px bg-champagne-400" id="process-progress" style="height:0"></span>

        {
          processSteps.map((step) => (
            <li class="relative mb-12 flex gap-7 pl-0 last:mb-0" data-step>
              <span class="relative z-10 flex h-12 w-12 flex-none items-center justify-center rounded-full border border-cream/25 bg-sage-800 font-serif text-champagne-300 transition-colors" data-step-dot>
                {step.no}
              </span>
              <div class="pt-1.5">
                <h3 class="font-serif text-2xl">{step.title}</h3>
                <p class="mt-2 max-w-md text-sm font-light leading-relaxed text-cream/70">
                  {step.text}
                </p>
              </div>
            </li>
          ))
        }
      </ol>

      <!-- Görsel -->
      <div class="relative hidden lg:block" data-reveal>
        <div class="overflow-hidden rounded-[2rem]">
          <img src={sideImg} alt="Konsept ve çiçek tasarımı detayı" loading="lazy" class="h-[34rem] w-full object-cover" />
        </div>
        <div class="absolute -bottom-6 -left-6 rounded-2xl border border-champagne-400/40 bg-sage-900/80 px-7 py-5 backdrop-blur">
          <p class="font-display text-3xl text-champagne-300">12 yıl</p>
          <p class="text-xs uppercase tracking-wide-sm text-cream/60">kusursuz organizasyon</p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const tl = document.getElementById('process-timeline');
  const progress = document.getElementById('process-progress');
  if (tl && progress) {
    // çizgi yüksekliğini kaydırmaya bağla
    ScrollTrigger.create({
      trigger: tl,
      start: 'top 70%',
      end: 'bottom 70%',
      onUpdate: (self) => {
        progress.style.height = `${self.progress * 100}%`;
      },
    });

    // adım noktalarını aktive et
    tl.querySelectorAll('[data-step]').forEach((step) => {
      const dot = step.querySelector('[data-step-dot]') as HTMLElement;
      ScrollTrigger.create({
        trigger: step,
        start: 'top 75%',
        onEnter: () => {
          dot.style.backgroundColor = '#d9c4a0';
          dot.style.color = '#2f372c';
          dot.style.borderColor = '#d9c4a0';
        },
        onLeaveBack: () => {
          dot.style.backgroundColor = '';
          dot.style.color = '';
          dot.style.borderColor = '';
        },
      });
    });
  }
</script>
