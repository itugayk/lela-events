---
// İnce çizgisel süsleme — merkezde küçük bir motif, iki yanda hatlar
interface Props {
  label?: string;
  light?: boolean;
}
const { label, light = false } = Astro.props;
const tone = light ? 'text-cream/70' : 'text-champagne-700';
const line = light ? 'via-cream/40' : 'via-champagne-400';
---

<div class="flex items-center justify-center gap-4">
  <span class={`h-px w-16 bg-gradient-to-r from-transparent ${line} to-transparent sm:w-24`}></span>
  <span class={`flex items-center gap-2 text-[0.7rem] uppercase tracking-luxe ${tone}`}>
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" class="opacity-80">
      <path d="M12 2 L14 10 L22 12 L14 14 L12 22 L10 14 L2 12 L10 10 Z" fill="currentColor" />
    </svg>
    {label && <span>{label}</span>}
  </span>
  <span class={`h-px w-16 bg-gradient-to-r from-transparent ${line} to-transparent sm:w-24`}></span>
</div>
