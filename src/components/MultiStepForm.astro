---
import Ornament from './Ornament.astro';

const eventTypes = [
  { value: 'dugun', label: 'Düğün', icon: 'M8 14a4 4 0 1 0 0-8 4 4 0 0 0 0 8Zm8 4a4 4 0 1 0 0-8 4 4 0 0 0 0 8Z' },
  { value: 'nisan', label: 'Nişan', icon: 'M12 21s-7-4.7-9.3-9.2C1 8.4 2.7 5 6 5c2 0 3.2 1.3 4 2.5C10.8 6.3 12 5 14 5c3.3 0 5 3.4 3.3 6.8C19 16.3 12 21 12 21Z' },
  { value: 'kina', label: 'Kına', icon: 'M12 2c1 3-2 4-2 7a2 2 0 1 0 4 0c2 1.5 3 3.5 3 6a5 5 0 1 1-10 0c0-4 5-6 5-13Z' },
  { value: 'kurumsal', label: 'Kurumsal', icon: 'M4 21V5l8-3 8 3v16M9 9h.01M9 13h.01M15 9h.01M15 13h.01' },
  { value: 'konsept', label: 'Konsept Tasarım', icon: 'M12 3a9 9 0 1 0 0 18c1.5 0 2-1 2-2s-1-1.5-1-2.5 1-1.5 2-1.5h1a4 4 0 0 0 4-4c0-4.4-3.6-8-8-8Z' },
];

const guestRanges = ['0 - 50', '50 - 150', '150 - 300', '300 - 500', '500+'];
const budgetRanges = ['150.000 ₺ altı', '150.000 - 350.000 ₺', '350.000 - 750.000 ₺', '750.000 ₺ üzeri', 'Henüz net değil'];
const steps = ['Etkinlik', 'Tarih', 'Kişi', 'Bütçe', 'İletişim'];
---

<section id="teklif" class="relative overflow-hidden bg-ivory py-24 lg:py-32">
  <div class="glow-soft pointer-events-none absolute left-1/2 top-0 h-[28rem] w-[28rem] -translate-x-1/2 opacity-60"></div>

  <div class="mx-auto max-w-3xl px-6 lg:px-10">
    <div class="text-center" data-reveal>
      <Ornament label="Teklif Al" />
      <h2 class="mt-6 font-display text-4xl leading-tight sm:text-5xl">
        Hayalinizi <span class="italic text-sage-500">birlikte</span> planlayalım
      </h2>
      <p class="mx-auto mt-4 max-w-lg text-sm font-light leading-relaxed text-ink/60">
        Birkaç soruyla başlayalım — size 24 saat içinde özel bir konsept ve teklifle dönelim.
      </p>
    </div>

    <!-- Form kartı -->
    <div class="mt-12 rounded-[2rem] border border-champagne-200 bg-cream p-7 shadow-xl shadow-champagne-100/60 sm:p-11" data-reveal data-delay="0.1">
      <!-- İlerleme göstergesi -->
      <div id="form-progress" class="mb-10">
        <div class="mb-3 flex justify-between">
          {
            steps.map((label, i) => (
              <div class="flex flex-1 flex-col items-center gap-2" data-prog-step={i}>
                <span class="flex h-8 w-8 items-center justify-center rounded-full border text-xs transition-all duration-300" data-prog-dot>
                  {i + 1}
                </span>
                <span class="hidden text-[0.6rem] uppercase tracking-wide-sm text-ink/50 sm:block" data-prog-label>{label}</span>
              </div>
            ))
          }
        </div>
        <div class="h-1 w-full overflow-hidden rounded-full bg-champagne-200">
          <div class="h-full rounded-full bg-sage-500 transition-all duration-500" id="prog-bar" style="width:20%"></div>
        </div>
      </div>

      <form id="quote-form" novalidate>
        <!-- ADIM 1: Etkinlik türü -->
        <div class="step-pane" data-pane="0">
          <h3 class="mb-1 font-serif text-2xl">Hangi etkinliği planlıyorsunuz?</h3>
          <p class="mb-6 text-sm text-ink/55">Size en uygun konsepti birlikte belirleyelim.</p>
          <div class="grid grid-cols-2 gap-3 sm:grid-cols-3">
            {
              eventTypes.map((t) => (
                <label class="group relative cursor-pointer">
                  <input type="radio" name="eventType" value={t.label} class="peer sr-only" required />
                  <div class="flex flex-col items-center gap-3 rounded-2xl border border-champagne-200 bg-ivory px-4 py-6 text-center transition-all peer-checked:border-sage-400 peer-checked:bg-sage-50 peer-checked:shadow-md hover:border-champagne-400">
                    <span class="flex h-11 w-11 items-center justify-center rounded-full bg-champagne-100 text-sage-600 transition-colors group-has-[:checked]:bg-sage-500 group-has-[:checked]:text-ivory">
                      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d={t.icon}/></svg>
                    </span>
                    <span class="text-sm font-medium text-ink/80">{t.label}</span>
                  </div>
                </label>
              ))
            }
          </div>
          <p class="mt-3 hidden text-sm text-rose-500" data-err="0">Lütfen bir etkinlik türü seçin.</p>
        </div>

        <!-- ADIM 2: Tarih -->
        <div class="step-pane hidden" data-pane="1">
          <h3 class="mb-1 font-serif text-2xl">Aklınızdaki tarih?</h3>
          <p class="mb-6 text-sm text-ink/55">Net bir tarihiniz yoksa esnek seçeneğini işaretleyebilirsiniz.</p>
          <input
            type="date"
            name="eventDate"
            class="w-full rounded-xl border border-champagne-200 bg-ivory px-5 py-4 text-ink/80 outline-none transition-colors focus:border-sage-400"
          />
          <label class="mt-4 flex items-center gap-3 text-sm text-ink/70">
            <input type="checkbox" name="flexibleDate" class="h-4 w-4 accent-sage-500" />
            Tarih konusunda esneğim
          </label>
          <p class="mt-3 hidden text-sm text-rose-500" data-err="1">Lütfen bir tarih seçin ya da esnek olduğunuzu belirtin.</p>
        </div>

        <!-- ADIM 3: Kişi -->
        <div class="step-pane hidden" data-pane="2">
          <h3 class="mb-1 font-serif text-2xl">Yaklaşık kaç davetli?</h3>
          <p class="mb-6 text-sm text-ink/55">Tahmini bir aralık seçmeniz yeterli.</p>
          <div class="grid grid-cols-2 gap-3 sm:grid-cols-3">
            {
              guestRanges.map((g) => (
                <label class="cursor-pointer">
                  <input type="radio" name="guests" value={g} class="peer sr-only" required />
                  <div class="rounded-xl border border-champagne-200 bg-ivory px-4 py-4 text-center text-sm text-ink/75 transition-all peer-checked:border-sage-400 peer-checked:bg-sage-50 peer-checked:font-medium peer-checked:text-sage-700 hover:border-champagne-400">
                    {g}
                  </div>
                </label>
              ))
            }
          </div>
          <p class="mt-3 hidden text-sm text-rose-500" data-err="2">Lütfen bir davetli aralığı seçin.</p>
        </div>

        <!-- ADIM 4: Bütçe -->
        <div class="step-pane hidden" data-pane="3">
          <h3 class="mb-1 font-serif text-2xl">Bütçe aralığınız?</h3>
          <p class="mb-6 text-sm text-ink/55">Bu bilgi, size en uygun konsepti sunmamıza yardımcı olur.</p>
          <div class="space-y-3">
            {
              budgetRanges.map((b) => (
                <label class="cursor-pointer">
                  <input type="radio" name="budget" value={b} class="peer sr-only" required />
                  <div class="flex items-center gap-3 rounded-xl border border-champagne-200 bg-ivory px-5 py-4 text-sm text-ink/75 transition-all peer-checked:border-sage-400 peer-checked:bg-sage-50 peer-checked:text-sage-700 hover:border-champagne-400">
                    <span class="flex h-4 w-4 flex-none items-center justify-center rounded-full border border-champagne-400 peer-checked:border-sage-500">
                      <span class="h-2 w-2 rounded-full bg-sage-500 opacity-0 transition-opacity peer-checked:opacity-100"></span>
                    </span>
                    {b}
                  </div>
                </label>
              ))
            }
          </div>
          <p class="mt-3 hidden text-sm text-rose-500" data-err="3">Lütfen bir bütçe aralığı seçin.</p>
        </div>

        <!-- ADIM 5: İletişim -->
        <div class="step-pane hidden" data-pane="4">
          <h3 class="mb-1 font-serif text-2xl">Sizi nasıl bulalım?</h3>
          <p class="mb-6 text-sm text-ink/55">Hazırladığımız konsepti paylaşmak için iletişim bilgileriniz.</p>
          <div class="space-y-4">
            <div>
              <input type="text" name="name" placeholder="Ad Soyad" class="w-full rounded-xl border border-champagne-200 bg-ivory px-5 py-4 text-ink/80 outline-none transition-colors focus:border-sage-400" required />
              <p class="mt-1.5 hidden text-sm text-rose-500" data-field-err="name">Lütfen adınızı girin.</p>
            </div>
            <div>
              <input type="email" name="email" placeholder="E-posta" class="w-full rounded-xl border border-champagne-200 bg-ivory px-5 py-4 text-ink/80 outline-none transition-colors focus:border-sage-400" required />
              <p class="mt-1.5 hidden text-sm text-rose-500" data-field-err="email">Geçerli bir e-posta adresi girin.</p>
            </div>
            <div>
              <input type="tel" name="phone" placeholder="Telefon" class="w-full rounded-xl border border-champagne-200 bg-ivory px-5 py-4 text-ink/80 outline-none transition-colors focus:border-sage-400" required />
              <p class="mt-1.5 hidden text-sm text-rose-500" data-field-err="phone">Geçerli bir telefon numarası girin.</p>
            </div>
            <textarea name="message" rows="3" placeholder="Eklemek istedikleriniz (opsiyonel)" class="w-full resize-none rounded-xl border border-champagne-200 bg-ivory px-5 py-4 text-ink/80 outline-none transition-colors focus:border-sage-400"></textarea>
          </div>
        </div>

        <!-- Navigasyon -->
        <div class="mt-9 flex items-center justify-between">
          <button type="button" id="btn-prev" class="invisible rounded-full px-6 py-3 text-sm uppercase tracking-wide-sm text-ink/60 transition-colors hover:text-sage-700">
            ← Geri
          </button>
          <button type="button" id="btn-next" class="btn-sheen rounded-full bg-sage-500 px-9 py-3.5 text-sm uppercase tracking-wide-sm text-ivory transition-transform hover:scale-105">
            Devam
          </button>
          <button type="submit" id="btn-submit" class="btn-sheen hidden rounded-full bg-champagne-500 px-9 py-3.5 text-sm uppercase tracking-wide-sm text-sage-900 transition-transform hover:scale-105">
            Teklif İste
          </button>
        </div>
      </form>

      <!-- Başarı durumu -->
      <div id="form-success" class="hidden py-10 text-center">
        <div class="mx-auto flex h-20 w-20 items-center justify-center rounded-full bg-sage-100">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#6f7f62" stroke-width="1.5"><path d="M20 6 9 17l-5-5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <h3 class="mt-6 font-display text-3xl text-sage-700">Teşekkürler!</h3>
        <p class="mx-auto mt-3 max-w-sm text-sm leading-relaxed text-ink/60" id="success-summary">
          Talebiniz bize ulaştı. 24 saat içinde size özel konsept ve teklifle döneceğiz.
        </p>
        <button type="button" id="btn-reset" class="mt-8 rounded-full border border-sage-400 px-7 py-3 text-sm uppercase tracking-wide-sm text-sage-700 transition-colors hover:bg-sage-500 hover:text-ivory">
          Yeni Talep
        </button>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('quote-form') as HTMLFormElement | null;
  if (form) {
    const panes = Array.from(document.querySelectorAll<HTMLElement>('[data-pane]'));
    const progSteps = Array.from(document.querySelectorAll<HTMLElement>('[data-prog-step]'));
    const progBar = document.getElementById('prog-bar')!;
    const btnPrev = document.getElementById('btn-prev')!;
    const btnNext = document.getElementById('btn-next')!;
    const btnSubmit = document.getElementById('btn-submit')!;
    const success = document.getElementById('form-success')!;
    const total = panes.length;
    let current = 0;

    const showPane = (n: number, dir = 1) => {
      panes.forEach((p, i) => {
        const active = i === n;
        p.classList.toggle('hidden', !active);
        if (active) {
          p.style.opacity = '0';
          p.style.transform = `translateX(${dir * 30}px)`;
          requestAnimationFrame(() => {
            p.style.opacity = '1';
            p.style.transform = 'translateX(0)';
          });
        }
      });
      // ilerleme
      progBar.style.width = `${((n + 1) / total) * 100}%`;
      progSteps.forEach((s, i) => {
        const dot = s.querySelector('[data-prog-dot]') as HTMLElement;
        const done = i < n;
        const isCurrent = i === n;
        dot.style.borderColor = done || isCurrent ? '#6f7f62' : '#e0caa5';
        dot.style.backgroundColor = done ? '#6f7f62' : isCurrent ? '#f4f6f1' : 'transparent';
        dot.style.color = done ? '#fdfbf7' : isCurrent ? '#57654c' : '#b3925f';
        dot.innerHTML = done ? '✓' : String(i + 1);
      });
      // butonlar
      btnPrev.classList.toggle('invisible', n === 0);
      btnNext.classList.toggle('hidden', n === total - 1);
      btnSubmit.classList.toggle('hidden', n !== total - 1);
    };

    const validateStep = (n: number): boolean => {
      // hata mesajlarını gizle
      const err = document.querySelector(`[data-err="${n}"]`) as HTMLElement | null;
      err?.classList.add('hidden');

      if (n === 0) {
        if (!form.querySelector<HTMLInputElement>('input[name="eventType"]:checked')) { err?.classList.remove('hidden'); return false; }
      }
      if (n === 1) {
        const date = form.querySelector<HTMLInputElement>('input[name="eventDate"]')!;
        const flex = form.querySelector<HTMLInputElement>('input[name="flexibleDate"]')!;
        if (!date.value && !flex.checked) { err?.classList.remove('hidden'); return false; }
      }
      if (n === 2) {
        if (!form.querySelector<HTMLInputElement>('input[name="guests"]:checked')) { err?.classList.remove('hidden'); return false; }
      }
      if (n === 3) {
        if (!form.querySelector<HTMLInputElement>('input[name="budget"]:checked')) { err?.classList.remove('hidden'); return false; }
      }
      if (n === 4) {
        let ok = true;
        const name = form.querySelector<HTMLInputElement>('input[name="name"]')!;
        const email = form.querySelector<HTMLInputElement>('input[name="email"]')!;
        const phone = form.querySelector<HTMLInputElement>('input[name="phone"]')!;
        const setErr = (field: string, bad: boolean) => {
          const el = document.querySelector(`[data-field-err="${field}"]`) as HTMLElement;
          el?.classList.toggle('hidden', !bad);
          if (bad) ok = false;
        };
        setErr('name', name.value.trim().length < 2);
        setErr('email', !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email.value));
        setErr('phone', phone.value.replace(/[^\d]/g, '').length < 7);
        return ok;
      }
      return true;
    };

    btnNext.addEventListener('click', () => {
      if (!validateStep(current)) return;
      if (current < total - 1) { current++; showPane(current, 1); }
    });
    btnPrev.addEventListener('click', () => {
      if (current > 0) { current--; showPane(current, -1); }
    });

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      if (!validateStep(current)) return;
      const data = new FormData(form);
      const type = data.get('eventType');
      const guests = data.get('guests');
      // özet
      const summary = document.getElementById('success-summary')!;
      summary.textContent = `${data.get('name')}, ${type} organizasyonunuz (${guests} kişi) için talebiniz bize ulaştı. 24 saat içinde size özel konsept ve teklifle döneceğiz.`;
      form.classList.add('hidden');
      document.getElementById('form-progress')!.classList.add('hidden');
      success.classList.remove('hidden');
      success.scrollIntoView({ behavior: 'smooth', block: 'center' });
    });

    document.getElementById('btn-reset')!.addEventListener('click', () => {
      form.reset();
      current = 0;
      showPane(0);
      form.classList.remove('hidden');
      document.getElementById('form-progress')!.classList.remove('hidden');
      success.classList.add('hidden');
    });

    showPane(0);
  }
</script>
