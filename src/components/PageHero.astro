---
import Ornament from './Ornament.astro';
interface Props {
  kicker?: string;
  title: string;
  subtitle?: string;
  image: string;
}
const { kicker, title, subtitle, image } = Astro.props;
---

<section class="relative flex h-[60vh] min-h-[420px] items-center justify-center overflow-hidden">
  <div class="absolute inset-0">
    <img src={image} alt={title} class="h-full w-full scale-105 object-cover" data-page-hero-img fetchpriority="high" />
    <div class="absolute inset-0 bg-gradient-to-b from-ink/45 via-ink/30 to-ink/55"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-ivory/85 via-transparent to-transparent"></div>
  </div>
  <div class="glow-soft pointer-events-none absolute left-1/2 top-1/2 h-[30rem] w-[30rem] -translate-x-1/2 -translate-y-1/2 opacity-50"></div>

  <div class="relative z-10 px-6 text-center text-cream">
    <div data-reveal-fade>
      <Ornament label={kicker} light />
    </div>
    <h1 class="mt-6 font-display text-5xl leading-[1.05] sm:text-6xl lg:text-7xl" data-reveal data-delay="0.15">{title}</h1>
    {subtitle && <p class="mx-auto mt-5 max-w-xl text-base font-light leading-relaxed text-cream/80" data-reveal data-delay="0.3">{subtitle}</p>}
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!reduce) {
    gsap.from('[data-page-hero-img]', { scale: 1.2, duration: 2, ease: 'power2.out' });
  }
</script>
